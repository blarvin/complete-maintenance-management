{
  "permissions": {
    "allow": [
      "Bash(npm run typecheck:*)",
      "Bash(npm run build.preview:*)",
      "Bash(npx vitest run)",
      "Bash(npx qwik:*)",
      "Bash(npx tsc:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebSearch",
      "Bash(find:*)",
      "Bash(echo:*)",
      "WebFetch(domain:github.com)",
      "mcp__jcodemunch__index_folder",
      "mcp__jcodemunch__list_repos",
      "mcp__jcodemunch__get_file_tree",
      "mcp__jcodemunch__search_symbols",
      "mcp__jcodemunch__get_symbol",
      "mcp__jcodemunch__get_file_outline",
      "Bash(npx vitest:*)",
      "mcp__jcodemunch__get_file_content",
      "Bash(cd:*)",
      "Bash(grep -E \"\\\\.tsx$\")",
      "Bash(npm run *)",
      "Bash(npx vite *)"
    ],
    "deny": [
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); FILE_PATH=$(echo \"$INPUT\" | jq -r \".tool_input.file_path // empty\"); case \"$FILE_PATH\" in */package-lock.json|*.env|*.env.*|*/SPECIFICATION.md) echo \"BLOCKED: Protected file $FILE_PATH — do not edit directly\" >&2; exit 2;; esac'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-tool-use.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"[System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms') | Out-Null; [System.Windows.Forms.MessageBox]::Show('Claude Code needs your input', 'Claude Code', 'OK', 'Information') | Out-Null\""
          }
        ]
      }
    ]
  }
}
